{
    "name": "app-template",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "node ./node_modules/vite/bin/vite.js --configLoader native --host 0.0.0.0",
        "build": "tsc --noEmit && node ./node_modules/vite/bin/vite.js build --configLoader native",
        "preview": "node ./node_modules/vite/bin/vite.js preview --configLoader native --host 0.0.0.0",
        "electron:dev": "node ./scripts/electron-dev.mjs",
        "electron:start": "npm run build && electron .",
        "typecheck": "tsc --noEmit",
        "check": "npm run build",
        "assets:generate": "node ./scripts/generate-template-assets.mjs",
        "assets:verify": "node ./scripts/verify-assets.mjs",
        "assets:report": "node ./scripts/report-assets.mjs",
        "licenses": "node ./scripts/generate-third-party-notices.mjs"
    },
    "dependencies": {
        "@hookform/resolvers": "5.2.2",
        "localforage": "1.10.0",
        "lucide-react": "0.544.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-hook-form": "7.62.0",
        "react-router-dom": "7.13.1",
        "zod": "4.1.5",
        "zustand": "5.0.11"
    },
    "devDependencies": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.1.4",
        "electron": "^36.9.5",
        "typescript": "5.9.3",
        "vite": "7.3.1"
    }
}
